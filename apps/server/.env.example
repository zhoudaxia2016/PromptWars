# LLM API（三选一）
# OpenAI：配置后自动使用 api.openai.com
OPENAI_API_KEY=

# DeepSeek：配置后自动使用 api.deepseek.com
# DEEPSEEK_API_KEY=

# 其他模型：需同时配置 base_url 和 key
# LLM_BASE_URL=https://your-api.com/v1
# LLM_API_KEY=

# 可选：模型名。OpenAI 默认 gpt-4o-mini，DeepSeek 默认 deepseek-chat
# LLM_MODEL=gpt-4o-mini

# 可选：端口，默认 8000
# PORT=8000
